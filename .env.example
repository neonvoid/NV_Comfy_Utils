# ===========================================
# NV_Comfy_Utils - Environment Config
# ===========================================
# Copy this file to .env and fill in your values.
# Or set these as system environment variables.
# Environment variables take priority over .env values.

# ------------------------------------------
# API Keys (used by PromptRefiner, GeminiVideoCaptioner, GeminiVideoExtractor)
# ------------------------------------------
# Gemini (Google AI Studio) — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GOOGLE_API_KEY=  # alternative name, same key

# OpenRouter — get from https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# ------------------------------------------
# Slack Bot Token (Required)
# ------------------------------------------
# Get this from: https://api.slack.com/apps > Your App > OAuth & Permissions
# Starts with "xoxb-"
SLACK_BOT_TOKEN=

# ------------------------------------------
# Error Notification Channel (Optional)
# ------------------------------------------
# Where to send automatic error notifications
# Can be: #channel-name, channel ID (C...), or user ID (U...) for DMs
# Leave empty to disable automatic error notifications
SLACK_ERROR_CHANNEL=

# ------------------------------------------
# Finding Your User ID (for DMs)
# ------------------------------------------
# 1. Open Slack
# 2. Click your profile picture > Profile
# 3. Click the three dots menu
# 4. Select "Copy member ID"
# Example: U0ABC123XYZ
